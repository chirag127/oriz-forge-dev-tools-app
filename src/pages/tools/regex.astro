---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Regex tester — Oriz Dev Tools" description="Live regex tester with match highlighting. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Regex tester</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="fields">
      <div class="row">
        <label class="label" for="regex-pattern">Pattern</label>
        <div class="pattern-wrap">
          <span class="delim">/</span>
          <input id="regex-pattern" class="io-line" type="text" placeholder="(\w+)\s+(\w+)" spellcheck="false" autocomplete="off" />
          <span class="delim">/</span>
          <input id="regex-flags" class="io-flags" type="text" placeholder="gim" maxlength="6" spellcheck="false" autocomplete="off" />
        </div>
        <div id="regex-status" class="status-msg"></div>
      </div>

      <div class="row">
        <label class="label" for="regex-input">Test string</label>
        <textarea id="regex-input" class="io" rows="6" placeholder="Paste your test string here…"></textarea>
      </div>

      <div class="row">
        <div class="result-header">
          <span class="label">Highlighted matches</span>
          <span id="match-count" class="match-count mono">0 matches</span>
        </div>
        <div id="regex-highlight" class="highlight-box" aria-live="polite"></div>
      </div>

      <div class="row">
        <div class="label">Match groups</div>
        <table id="groups-table" class="groups-table">
          <thead><tr><th>#</th><th>match</th><th>groups</th><th>index</th></tr></thead>
          <tbody id="groups-body"></tbody>
        </table>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 0.4rem; letter-spacing: 0.05em; }
  .fields { display: flex; flex-direction: column; gap: 1.25rem; }
  .row { display: flex; flex-direction: column; }
  .pattern-wrap { display: flex; align-items: center; gap: 0; border: 1px solid var(--rule); background: var(--paper-2); }
  .delim { padding: 0 0.5rem; color: var(--muted); font-family: var(--font-mono); font-size: 1.1rem; user-select: none; }
  .io-line {
    flex: 1;
    padding: 0.6rem 0.25rem;
    background: transparent;
    border: none;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    outline: none;
  }
  .io-flags {
    width: 4.5rem;
    padding: 0.6rem 0.5rem;
    background: transparent;
    border-left: 1px solid var(--rule);
    border-right: none;
    border-top: none;
    border-bottom: none;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    outline: none;
  }
  .io {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    resize: vertical;
    outline: none;
  }
  .io:focus { border-color: var(--accent); }
  .status-msg { font-family: var(--font-mono); font-size: 0.75rem; min-height: 1.2rem; margin-top: 0.3rem; }
  .status-msg.ok { color: #4ade80; }
  .status-msg.err { color: #f87171; }
  .result-header { display: flex; align-items: baseline; justify-content: space-between; }
  .match-count { font-size: 11px; color: var(--muted); }
  .highlight-box {
    min-height: 3rem;
    padding: 0.875rem 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-all;
    color: var(--ink);
  }
  .highlight-box mark {
    background: rgba(56, 189, 248, 0.25);
    color: var(--accent);
    border-radius: 2px;
    outline: 1px solid rgba(56, 189, 248, 0.4);
  }
  .groups-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .groups-table th {
    text-align: left;
    padding: 0.4rem 0.75rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    font-size: 11px;
  }
  .groups-table td {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--rule);
    color: var(--ink);
    vertical-align: top;
  }
  .groups-table tr:hover td { background: var(--paper-2); }
  .groups-table .match-val { color: var(--accent); }
</style>

<script>
  const patternEl = document.getElementById('regex-pattern') as HTMLInputElement;
  const flagsEl = document.getElementById('regex-flags') as HTMLInputElement;
  const inputEl = document.getElementById('regex-input') as HTMLTextAreaElement;
  const highlightEl = document.getElementById('regex-highlight') as HTMLDivElement;
  const statusEl = document.getElementById('regex-status') as HTMLElement;
  const countEl = document.getElementById('match-count') as HTMLElement;
  const tbody = document.getElementById('groups-body') as HTMLTableSectionElement;

  function escape(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function update() {
    const pattern = patternEl.value;
    const flags = flagsEl.value;
    const text = inputEl.value;

    if (!pattern) {
      statusEl.textContent = '';
      highlightEl.textContent = text;
      countEl.textContent = '0 matches';
      tbody.innerHTML = '';
      return;
    }

    let rx: RegExp;
    try {
      // ensure 'g' for exec loop
      const f = flags.includes('g') ? flags : flags + 'g';
      rx = new RegExp(pattern, f);
      statusEl.className = 'status-msg ok';
      statusEl.textContent = '✓ valid';
    } catch(e: unknown) {
      statusEl.className = 'status-msg err';
      statusEl.textContent = '✗ ' + (e as Error).message;
      highlightEl.textContent = text;
      countEl.textContent = '0 matches';
      tbody.innerHTML = '';
      return;
    }

    // Build highlighted HTML
    const matches: RegExpExecArray[] = [];
    let m: RegExpExecArray | null;
    rx.lastIndex = 0;
    while ((m = rx.exec(text)) !== null) {
      matches.push(m);
      if (!rx.global) break;
    }

    countEl.textContent = matches.length + ' match' + (matches.length !== 1 ? 'es' : '');

    // Build HTML with marks
    let html = '';
    let cursor = 0;
    for (const match of matches) {
      html += escape(text.slice(cursor, match.index));
      html += `<mark title="match ${matches.indexOf(match)+1}">${escape(match[0])}</mark>`;
      cursor = match.index! + match[0].length;
    }
    html += escape(text.slice(cursor));
    highlightEl.innerHTML = html;

    // Groups table
    tbody.innerHTML = matches.map((match, i) => {
      const groups = match.slice(1).map((g, gi) =>
        `<span style="color:var(--muted)">[${gi+1}]</span> ${escape(g ?? 'undefined')}`
      ).join('<br>');
      return `<tr>
        <td>${i+1}</td>
        <td class="match-val">${escape(match[0])}</td>
        <td>${groups || '<span style="color:var(--muted)">none</span>'}</td>
        <td>${match.index}</td>
      </tr>`;
    }).join('');
  }

  patternEl.addEventListener('input', update);
  flagsEl.addEventListener('input', update);
  inputEl.addEventListener('input', update);
</script>
